# --- SECRÉTS ET MOTS DE PASSE (CRITIQUE) ---
# Fichiers spécifiques identifiés
mysql_root.txt
mail.key
base/mail-config.yaml

# Extensions universelles de secrets
*.txt
*.key
*.pem
*.p12
*.secret

# --- INFRASTRUCTURE & TLS ---
# On ignore les certificats et clés générés
tls/*.key
tls/*.crt
**/*.key
**/*.pem
**/certs/*

# --- FICHIERS LOURDS & CACHE ---
# Bases de données ClamAV
security/clamav/*.cvd
security/clamav/*.cld

# --- LOGS ET TEMPORAIRES ---
*.log
.DS_Store
.idea/
.vscode/
*.swp
